{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurotype",
  "version": "0.1.0",
  "identifier": "com.rchardx.aurotype",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aurotype",
        "label": "main",
        "width": 800,
        "height": 600
      },
      {
        "label": "float",
        "url": "float.html",
        "title": "",
        "width": 300,
        "height": 80,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "focusable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/aurotype-engine"]
  }
}
