{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurotype",
  "version": "0.2.0",
  "identifier": "com.rchardx.aurotype",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aurotype",
        "label": "main",
        "width": 800,
        "height": 600
      },
      {
        "label": "float",
        "url": "float.html",
        "title": "",
        "width": 320,
        "height": 96,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "focusable": false,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "backgroundColor": "#00000000",
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/aurotype-engine"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
